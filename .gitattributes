# Keep Linux shell scripts in LF format
*.sh text eol=lf

# Terraform files use LF
*.tf text eol=lf
*.tfvars text eol=lf

# YAML files use LF
*.yml text eol=lf
*.yaml text eol=lf

# Markdown
*.md text eol=lf

# Windows scripts (if we ever add them)
*.ps1 text eol=crlf

# Batch files
*.bat text eol=crlf